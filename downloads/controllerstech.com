}

#ct-popup {
  position: relative;
  background: #ffffff;
  padding: 32px 28px 28px;
  max-width: 520px;
  width: 92%;
  border-radius: 18px;
  text-align: center;
  box-shadow: 0 25px 60px rgba(0,0,0,0.25);
  border: 1px solid #e5e7eb;
  animation: ctFadeIn 0.3s ease;
}

/* Top accent bar */
#ct-popup::before {
  content: "";
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 5px;
  border-radius: 18px 18px 0 0;
  background: linear-gradient(90deg, #3b82f6, #22c55e);
}

#ct-popup h2 {
  margin: 12px 0 8px;
  font-size: 22px;
  color: #0f172a;
}

#ct-popup p {
  margin-bottom: 18px;
  color: #475569;
  font-size: 14px;
}

#ct-close {
  position: absolute;
  top: 12px;
  right: 16px;
  cursor: pointer;
  font-size: 20px;
  color: #64748b;
}

#ct-close:hover {
  color: #0f172a;
}

/* Form styling */
#ct-popup input[type="email"],
#ct-popup input[type="text"] {
  width: 100%;
  padding: 12px;
  border-radius: 10px;
  border: 1px solid #cbd5e1;
  margin-bottom: 10px;
  font-size: 14px;
}

#ct-popup input:focus {
  outline: none;
  border-color: #3b82f6;
  box-shadow: 0 0 0 2px rgba(59,130,246,0.15);
}

#ct-popup button,
#ct-popup input[type="submit"] {
  width: 100%;
  background: linear-gradient(90deg, #3b82f6, #2563eb);
  color: #fff;
  border: none;
  padding: 12px;
  border-radius: 10px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

#ct-popup button:hover,
#ct-popup input[type="submit"]:hover {
  transform: translateY(-1px);
  box-shadow: 0 6px 16px rgba(37,99,235,0.25);
}

/* subtle animation */
@keyframes ctFadeIn {
  from { opacity: 0; transform: translateY(20px) scale(0.96); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}
</style>

<div id="ct-popup-overlay">
  <div id="ct-popup">
    <div id="ct-close">&times;</div>

