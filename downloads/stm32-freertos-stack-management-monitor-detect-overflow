<script>
document.addEventListener('DOMContentLoaded', function() {
  const POPUP_KEY = 'ct_popup_shown';
  const DAYS = 7;

  function setPopupSeen() {
    const expiry = new Date().getTime() + (DAYS * 24 * 60 * 60 * 1000);
    localStorage.setItem(POPUP_KEY, expiry);
  }

  function hasSeenPopup() {
    const expiry = localStorage.getItem(POPUP_KEY);
    if (!expiry) return false;

    if (new Date().getTime() > expiry) {
      localStorage.removeItem(POPUP_KEY);
      return false;
    }
    return true;
  }

  if (hasSeenPopup()) return;

  let shown = false;

  document.addEventListener('mouseout', function(e) {
    if (!shown && e.clientY < 10) {
      document.getElementById('ct-popup-overlay').style.display = 'flex';
      shown = true;
      setPopupSeen(); // mark as seen when shown
    }
  });

  document.getElementById('ct-close').onclick = function() {
    document.getElementById('ct-popup-overlay').style.display = 'none';
    setPopupSeen(); // also mark when closed
  };

  document.getElementById('ct-popup-overlay').onclick = function(e) {
    if (e.target === this) {
      this.style.display = 'none';
      setPopupSeen();
    }
  };
});
</script>

