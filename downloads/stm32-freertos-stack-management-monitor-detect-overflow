document.addEventListener('DOMContentLoaded', function() {

  var menuSource = document.getElementById('ct-nav-source');
  if (!menuSource) return;

  var panel = document.createElement('div');
  panel.className = 'ct-left-nav';
  panel.innerHTML =
    '<div class="ct-left-nav-inner">' +
    '<p class="ct-left-nav-title">Browse STM32 HAL Tutorials</p>' +
    menuSource.innerHTML +
    '</div>';

  document.body.appendChild(panel);

  var header = document.querySelector('header');

  function getHeaderHeight() {
    if (!header) return 0;
    var rect = header.getBoundingClientRect();
    return Math.max(0, rect.bottom);
  }

  function positionPanel() {

    var content = document.querySelector('.l-section.height_medium');
    var footer = document.querySelector('footer');
    if (!content) return;

    var rect = content.getBoundingClientRect();
    var panelWidth = panel.offsetWidth;

    // Hide on small screens
    if (window.innerWidth <= 1200) {
      panel.style.opacity = '0';
      panel.style.pointerEvents = 'none';
      return;
    }

    /* ------------------ LEFT POSITION (content-based) ------------------ */
    var left = rect.left - panelWidth - 15;



    /* ------------------ TOP POSITION (your original smooth logic) ------------------ */
    var headerBottom = getHeaderHeight();
    var topValue = headerBottom + 10;

    if (footer) {
      var footerTop = footer.getBoundingClientRect().top;
      var panelHeight = panel.offsetHeight;
      var panelBottom = topValue + panelHeight;

      if (panelBottom > footerTop - 10) {
        topValue = footerTop - panelHeight - 10;
      }
    }

    /* ------------------ APPLY ------------------ */
    panel.style.left = left + 'px';
    panel.style.top = topValue + 'px';
    panel.style.maxHeight = 'calc(100vh - ' + (headerBottom + 10) + 'px)';

    panel.style.opacity = '1';
    panel.style.pointerEvents = 'auto';
  }

  positionPanel();
  window.addEventListener('scroll', positionPanel);
  window.addEventListener('resize', positionPanel);

});
</script>

