<span class="line"><span style="color: #E53935">           task1Stack</span><span style="color: #39ADB5">,</span><span style="color: #E53935"> task2Stack</span><span style="color: #39ADB5">,</span><span style="color: #E53935"> task3Stack</span><span style="color: #39ADB5">);</span></span>
