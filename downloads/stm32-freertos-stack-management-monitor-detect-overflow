<span class="line"><span style="color: #E53935">    </span><span style="color: #6182B8">osDelay</span><span style="color: #39ADB5">(</span><span style="color: #F76D47">5000</span><span style="color: #39ADB5">);</span><span style="color: #90A4AE; font-style: italic">  // Wait 5 seconds between measurements</span></span>
<span class="line"><span style="color: #E53935">    </span></span>
<span class="line"><span style="color: #E53935">    task1Stack </span><span style="color: #39ADB5">=</span><span style="color: #E53935"> </span><span style="color: #6182B8">osThreadGetStackSpace</span><span style="color: #39ADB5">(</span><span style="color: #E53935">Task1Handle</span><span style="color: #39ADB5">);</span></span>
<span class="line"><span style="color: #E53935">    task2Stack </span><span style="color: #39ADB5">=</span><span style="color: #E53935"> </span><span style="color: #6182B8">osThreadGetStackSpace</span><span style="color: #39ADB5">(</span><span style="color: #E53935">Task2Handle</span><span style="color: #39ADB5">);</span></span>
